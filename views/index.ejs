<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mahfuj Mustafa - Resume</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <canvas id="mesh-bg"></canvas>
    <div class="page">
        <div class="contact-info">
            <span class="line accent">(347) 844-44127</span>
            <span class="line accent">MAHFUJMUSTAFA527@GMAIL.COM</span>
            <span class="line">NEW YORK CITY, NY</span>
        </div>

        <%
            // higher = constellation sits lower, less text clipped
            const CO = 38;

            const pts = [
                { x: 30,  by: 30 },
                { x: 130, by: 12 },
                { x: 250, by: 35 },
                { x: 310, by: 18 },
                { x: 420, by: 25 },
                { x: 500, by: 10 },
                { x: 580, by: 38 },
                { x: 680, by: 15 },
                { x: 760, by: 30 },
                { x: 870, by: 12 },
                { x: 960, by: 28 },
            ];
            const nodes = pts.map(p => ({ x: p.x, y: p.by + CO }));
            const maskPoly = ['0,' + nodes[0].y]
                .concat(nodes.map(n => n.x + ',' + n.y))
                .concat(['1000,' + nodes[nodes.length-1].y, '1000,110', '0,110'])
                .join(' ');
            const lineOps  = [0.5, 0.5, 0.5, 0.5, 0.5, 0.5, 0.5, 0.5, 0.5, 0.5];
            const dotR     = [3.5, 3, 4, 2.5, 3.5, 3, 3.5, 2.5, 3.5, 3, 2.5];
            const dotOps   = [0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7];
        %>
        <svg class="hero-title" viewBox="0 0 1000 110" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <mask id="name-mask">
                    <rect x="0" y="0" width="1000" height="110" fill="white"/>
                    <polygon points="<%= maskPoly %>" fill="black"/>
                </mask>
            </defs>

            <text x="500" y="65" text-anchor="middle" mask="url(#name-mask)"
                  font-family="'Roboto Mono', monospace" font-size="90" font-weight="700"
                  fill="#c8c8c8" letter-spacing="3">MAHFUJ MUSTAFA</text>

            <% for (let i = 0; i < nodes.length - 1; i++) { %>
            <line x1="<%= nodes[i].x %>" y1="<%= nodes[i].y %>" x2="<%= nodes[i+1].x %>" y2="<%= nodes[i+1].y %>" stroke="#e88aab" stroke-width="1" stroke-opacity="<%= lineOps[i] %>"/>
            <% } %>

            <% for (let i = 0; i < nodes.length; i++) { %>
            <circle cx="<%= nodes[i].x %>" cy="<%= nodes[i].y %>" r="<%= dotR[i] %>" fill="#e88aab" fill-opacity="<%= dotOps[i] %>"/>
            <% } %>
        </svg>

