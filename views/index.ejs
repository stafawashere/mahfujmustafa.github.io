        <%
            // circuit y offset — higher = lower
            const CO = 38;

            const pts = [
                { x: 30,  by: 30 },
                { x: 130, by: 15 },
                { x: 250, by: 30 },
                { x: 310, by: 18 },
                { x: 415, by: 30 },
                { x: 507, by: 15 },
                { x: 584, by: 30 },
                { x: 680, by: 15 },
                { x: 756, by: 30 },
                { x: 870, by: 23 },
                { x: 960, by: 32 },
            ];
            const nodes = pts.map(p => ({ x: p.x, y: p.by + CO }));

            const maskPoly = ["0," + nodes[0].y]
                .concat(nodes.map(n => n.x + "," + n.y))
                .concat(["1000," + nodes[nodes.length-1].y, "1000,110", "0,110"])
                .join(" ");

            const lineOps = [0.5, 0.5, 0.5, 0.5, 0.5, 0.5, 0.5, 0.5, 0.5, 0.5];
            const dotR    = [3.5, 3, 4, 2.5, 3.5, 3, 3.5, 2.5, 3.5, 3, 2.5];
            const dotOps  = [0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7];

            const stubs = [
                { from: 1, dx: 0,   dy: 16,  endDot: 2 },
                { from: 3, dx: 15,  dy: 14,  endDot: 1.5 },
                { from: 4, dx: 0,   dy: 14,  endDot: 2 },
                { from: 6, dx: -12, dy: 13,  endDot: 1.8 },
                { from: 8, dx: 0,   dy: 14,  endDot: 2 },
                { from: 9, dx: 14,  dy: 10,  endDot: 1.5 },
            ];

            const resolvedStubs = stubs.map(s => {
                const ox = nodes[s.from].x;
                const oy = nodes[s.from].y;
                return { x1: ox, y1: oy, x2: ox + s.dx, y2: oy + s.dy, endDot: s.endDot };
            });

            const tracePath = "M " + nodes.map(n => n.x + " " + n.y).join(" L ");
        %>

        <svg class="hero-title" viewBox="0 0 1000 110" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <mask id="name-mask">
                    <rect x="0" y="0" width="1000" height="110" fill="white"/>
                    <polygon points="<%= maskPoly %>" fill="black"/>
                </mask>

                <pattern id="pcb-grid" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
                    <circle cx="10" cy="10" r="0.6" fill="#e88aab" opacity="0.12"/>
                </pattern>

                <radialGradient id="glow-grad" cx="0.5" cy="0.5" r="0.5">
                    <stop offset="0%" stop-color="white"/>
                    <stop offset="100%" stop-color="black"/>
                </radialGradient>

                <mask id="glow-mask">
                    <rect id="glow-rect" x="0" y="0" width="200" height="200" fill="url(#glow-grad)" transform="translate(-9999, -9999)"/>
                    <rect id="pulse-glow-rect" x="0" y="0" width="160" height="160" fill="url(#glow-grad)" transform="translate(-9999, -9999)"/>
                    <polygon points="<%= maskPoly %>" fill="black"/>
                </mask>

                <filter id="pulse-glow" x="-50%" y="-50%" width="200%" height="200%">
                    <feGaussianBlur stdDeviation="3" result="blur"/>
                    <feMerge>
                        <feMergeNode in="blur"/>
                        <feMergeNode in="SourceGraphic"/>
                    </feMerge>
                </filter>

                <filter id="letterpress" x="-5%" y="-5%" width="110%" height="120%">
                    <feOffset dx="0" dy="3.5" in="SourceAlpha" result="off"/>
                    <feGaussianBlur stdDeviation="1" in="off" result="blur"/>
                    <feFlood flood-color="#000" flood-opacity="0.2" result="shadow"/>
                    <feComposite in="shadow" in2="blur" operator="in" result="inset"/>
                    <feMerge>
                        <feMergeNode in="SourceGraphic"/>
                        <feMergeNode in="inset"/>
                    </feMerge>
                </filter>
            </defs>

            <rect width="1000" height="110" fill="url(#pcb-grid)"/>

            <text x="500" y="65" text-anchor="middle" mask="url(#name-mask)"
                  font-family="'Roboto Mono', monospace" font-size="90" font-weight="700"
                  fill="#e6e6e6" letter-spacing="3" filter="url(#noise-texture)">MAHFUJ MUSTAFA</text>

            <text x="500" y="65" text-anchor="middle" mask="url(#glow-mask)"
                  font-family="'Roboto Mono', monospace" font-size="90" font-weight="700"
                  fill="#e87da3" letter-spacing="3" opacity="0.6" filter="url(#letterpress)">MAHFUJ MUSTAFA</text>


            <% for (let i = 0; i < nodes.length - 1; i++) { %>
            <line x1="<%= nodes[i].x %>" y1="<%= nodes[i].y %>" x2="<%= nodes[i+1].x %>" y2="<%= nodes[i+1].y %>" stroke="#e88aab" stroke-width="1" stroke-opacity="<%= lineOps[i] %>"/>
            <% } %>

            <% for (const stub of resolvedStubs) { %>
            <line x1="<%= stub.x1 %>" y1="<%= stub.y1 %>" x2="<%= stub.x2 %>" y2="<%= stub.y2 %>" stroke="#e88aab" stroke-width="0.6" stroke-opacity="0.12"/>
            <circle cx="<%= stub.x2 %>" cy="<%= stub.y2 %>" r="<%= stub.endDot %>" fill="#303030" stroke="#e88aab" stroke-width="0.4" stroke-opacity="0.15"/>
            <% } %>

            <g id="pulse-group">
                <animate attributeName="opacity" dur="5s" repeatCount="indefinite"
                         values="0;1;1;0;0" keyTimes="0;0.08;0.72;0.8;1"/>

                <circle id="pulse-dot" r="3" fill="#e88aab" filter="url(#pulse-glow)" opacity="0.9">
                    <animateMotion dur="5s" repeatCount="indefinite" path="<%= tracePath %>"
                                  keyPoints="0;1;1" keyTimes="0;0.8;1" calcMode="linear"/>
                    <animate attributeName="opacity" values="0.4;1;0.4" dur="1.5s" repeatCount="indefinite"/>
                </circle>

                <circle r="6" fill="none" stroke="#e88aab" stroke-width="0.8" opacity="0.3">
                    <animateMotion dur="5s" repeatCount="indefinite" path="<%= tracePath %>"
                                  keyPoints="0;1;1" keyTimes="0;0.8;1" calcMode="linear"/>
                    <animate attributeName="r" values="4;8;4" dur="1.5s" repeatCount="indefinite"/>
                    <animate attributeName="opacity" values="0.3;0.1;0.3" dur="1.5s" repeatCount="indefinite"/>
                </circle>
            </g>

            <% for (let i = 0; i < nodes.length; i++) { %>
            <circle class="circuit-node" cx="<%= nodes[i].x %>" cy="<%= nodes[i].y %>" r="<%= dotR[i] %>"
                    fill="#303030" stroke="#e88aab" stroke-width="0.7" stroke-opacity="<%= dotOps[i] %>"/>
            <% } %>
        </svg>

        <section>
